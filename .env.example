DATABASE_URL="file:./prisma/dev.db"

# LLM provider (OpenAI/Anthropic/DeepSeek) is configured from the app's
# Settings page at runtime, not an env var — the key lives encrypted in
# the SQLite db (see LlmSettings). Without one configured, recommendation
# generation falls back to StaticRecommendationProvider (free,
# deterministic, template-based — no network call).

# Required for WordPress integration and LLM settings (encrypting stored
# credentials at rest). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=""

# Google OAuth ("Desktop app" client type) — create one for free in
# Google Auth Platform console (console.cloud.google.com/auth/overview),
# add Search Console + GA4 readonly scopes, keep it in Testing mode and
# add each user as a test user (avoids Google's review process for <100
# users). Required only for the Search Console / Analytics tracking
# feature — everything else works without it.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
